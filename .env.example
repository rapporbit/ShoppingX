# 复制为 .env 后填入真实值。.env 已被 .gitignore 忽略，密钥不入库。
# 当前阶段（M0）只需 LLM 配置可用；召回 / Store / 平台 API 先占位，对应章节再补。

# ========== LLM 配置 ==========
# 主 / 子 AgentLoop 共用同一个 LLM（同质 fork 的核心要求）。OpenAI 兼容网关即可。
OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
OPENAI_API_KEY=sk-your-key
LLM_MAIN=your-main-model
LLM_JUDGE=your-judge-model
# 模型分层（perf/model-tiering）：**非推理快模型**，砍掉解码延迟（实测端到端 ~2/3 耗时是 reasoning
# 逐字解码）。它是全链路的默认档——子 Agent、planner / shopping_summary 等工具内部 LLM、以及**主
# loop 第 2 轮起**都用它。主 loop 只有**第 1 轮**（读 query、决定怎么编排的那次）用 LLM_MAIN 开
# reasoning：那是唯一没被机制锁死的决策；第 2 轮起决策空间已被阶段机白名单 + 候选 id 化夹死，
# thinking 花 7~10s 却买不到东西（见 app/harness/hooks/reasoning_boost.py）。
# **不配则回退 LLM_MAIN**（行为与未分层时一致、全同质）。配一个非推理快模型即可启用分层。
LLM_FAST=your-fast-nonreasoning-model
LLM_TEMPERATURE=0.3
LLM_JUDGE_TEMPERATURE=0.0
# 看图模型（M20 图搜 / image_understand）。主模型多为纯文本，图片只在该工具内部喂给 VL 模型，
# 主 loop 只见它吐出的文本结论。**不配 = 图搜整条腿优雅降级跳过**，其余功能不受影响。
# key / base_url 默认复用上面的 OPENAI_*；要指向别的供应商再单配 VISION_API_KEY / VISION_BASE_URL。
# 选型提示：现在的 hybrid 模型（如 qwen3.5-flash）本身就认图，**关掉思考后**比上一代专用视觉模型
# 更快更稳（实测同图 2.2s/185tok vs 4.8s 且单次能抖到 8.4s，识别质量打平）。默认已关思考，见下。
LLM_VISION=your-vision-model
# VISION_BASE_URL=            # 可选，缺省同 OPENAI_BASE_URL
# VISION_API_KEY=             # 可选，缺省同 OPENAI_API_KEY
# LLM_VISION_TEMPERATURE=0.1  # 可选，看图是读事实不是做创作，默认压到 0.1
# LLM_VISION_REASONING=off    # 可选，默认 off=关思考。「图里是什么」是感知题不是推理题：开思考
#                             # 实测 6.5s/790tok（668 是思考解码），关掉 2.2s/185tok，答案一模一样。
# 上传参考图的大小上限(MB)：图要转 base64 喂给 VL 模型，太大既费 token 又可能超 provider 限制。
UPLOAD_MAX_IMAGE_MB=8
# LLM_FAST_TEMPERATURE=0.3   # 可选，缺省同 LLM_TEMPERATURE
# FAST_MODE_REASONING_FIRST_ROUND=1  # 可选，置 0 则连第 1 轮也不开 reasoning（全程零思考，A/B 用）
# 单次 LLM 请求超时(秒) + 重试次数：没有请求超时时，一次卡死的 API 调用会一直挂到主 loop
# 全局预算才被杀，整条任务白跑。设了超时则卡住的调用会中断并换连接重试，任务自愈。
LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=2
# 主 loop 全局预算(秒)，跨平台多 fork 推理工作流偏长，默认 300 偏紧，按模型时延调。
MAIN_AGENT_TIMEOUT_SEC=600
# liveness 看门狗（hooks/watchdog.py）：停滞 STALL 秒无实质进展→注入强制收敛指令；
# 再过 GRACE 秒仍无进展→硬停交部分结果。远早于 MAIN_AGENT_TIMEOUT_SEC 的体面降级。
WATCHDOG_STALL_SEC=45
WATCHDOG_GRACE_SEC=30

# ========== 向量召回（M3 起用，Qdrant） ==========
# Qdrant collection 名（scripts/build_item_index.py 与检索侧共用）。
QDRANT_COLLECTION=shoppingx_items
# 商品/查询编码器：填了 EMBED_MODEL 走真实 embedding（OpenAI 兼容 /embeddings），
# 不填则走本地确定性回退（离线可跑、结果可复现），EMBED_DIM 仅回退时生效。
# EMBED_MODEL=bge-m3
# EMBED_BASE_URL=        # 缺省回退到 OPENAI_BASE_URL
# EMBED_API_KEY=         # 缺省回退到 OPENAI_API_KEY
EMBED_DIM=256

# 召回相关性下限（余弦）：低于此分的召回视为「最近邻但不相关」滤掉，让纯垃圾召回如实报 0
# （触发 web_search 兜底 / 空召回硬路径）。实测 BGE-M3 在本库：纯乱码 ≤0.40、真实 query 一律 ≥0.48
# （连库里没有的品类也 0.48-0.53），与「沾边 0.49-0.60 / 命中 0.56-0.70」重叠——故此阈值只挡乱码级
# 无关，挡不住「品类缺货」（数据稀疏问题，靠 prompt 诚实兜）。取 0.45。
RELEVANCE_FLOOR=0.45

# ========== RAG 品类知识库（M5 起用，CategoryInsight） ==========
# 配了 OPENSEARCH_HOST 走真 OpenSearch（docker/docker-compose.yml 起）；
# 不配则退化到进程内本地 hybrid（读 CATEGORY_CARDS_PATH 的 JSONL，离线/CI 可跑）。
# OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASS=shoppingx_dev_2026!
OPENSEARCH_USE_SSL=false
# 品类卡片落盘（scripts/build_category_kb.py 产出，已 gitignore）。
CATEGORY_CARDS_PATH=./data/rag/category_cards.jsonl
# Cross-encoder 精排（M3.6）：配了 ENDPOINT+MODEL+KEY 走标准 /v1/rerank（Cohere/Jina/硅基流动
# 同构），不配走确定性本地打分。KEY 缺省回退 EMBED_API_KEY / OPENAI_API_KEY（同供应商免重配）。
# RERANKER_ENDPOINT=https://api.siliconflow.cn/v1/rerank
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# RERANKER_API_KEY=         # 缺省回退 EMBED_API_KEY / OPENAI_API_KEY
# picker 品类一致性相关性分（cross-encoder；reranker 未配 / 降级本地回退时自动停用）：
# 普通轮低于 FLOOR 判跨品类混入、降权 W_RERANK_MISS 分（治炊具池混进背包）；套装轮作槽内
# 排序加分 W_SLOT_RERANK（真品在场时压下蹭词垃圾）。SLOT_FLOOR 是槽位逐出门，**默认 0=关**：
# 「品类内配件蹭词」场景绝对分数交叠（badcase 4c0ac682 标定），开门前必须重跑标定。
# PICK_RERANK_FLOOR=0.2
# PICK_W_RERANK_MISS=2.0
# PICK_SLOT_RERANK_FLOOR=0
# PICK_W_SLOT_RERANK=1.0

# ========== 长期记忆 Store ==========
# 无需配置：长期偏好 / 行为历史 / 收藏都存在下方「账户与会话归属库」的同一个关系库里
# （preferences / history_records / favorites 三张表，见 app/db/models.py），跟着 DATABASE_URL 走。
# 早年的 STORE_BACKEND=local|redis 已废弃——JSON 文件与 Redis 两条后端路径都不复存在。

# ========== 跨平台商品检索（占位） ==========
AMAZON_API_KEY=placeholder
SHOPEE_API_KEY=placeholder
ALIEXPRESS_API_KEY=placeholder
EBAY_API_KEY=placeholder

# ========== 预算币种 / 收货国解析 ==========
# 用户没写币种（如「预算 500」）时钉死的默认预算币种 ISO 码。planner 用纯规则解析币种，
# 解析不出才落这个默认值并在答案里标注「已按 <币种> 理解」，确保同一句话每次解析一致（确定性）。
DEFAULT_BUDGET_CURRENCY=CNY
# 用户没写收货国（「寄到日本」）时的默认收货国 ISO 码，决定关税免征额。同一套确定性范式：
# 规则解析不出才落默认值，并在答案里标注「到手价已按寄往 <国家> 估算」。
# 注意 CN 免征额仅 $7 —— 默认口径下几乎每单都会算出非零关税，标注不可省。
DEFAULT_DEST_COUNTRY=CN

# ========== Web 兜底搜索 ==========
TAVILY_API_KEY=your-tavily-key

# ========== fork 树检索预算（防失控）==========
# 一棵 fork 树（一次任务）的「商品检索」总量上限：主 loop 直调 + 各子 Agent 的 item_search /
# web_search 计进同一个全树计数（按 session_dir 聚合），超出即硬挡收尾。强制单平台一次召回后
# 给 8（5 子各 1 次 ≈5 + 主 loop 极少量直搜）；调小更早逼收尾、调大放宽召回广度。
RETRIEVAL_BUDGET=8
# 复用轮（planner 判 retrieval=reuse）的全树检索小预算：reuse 是假设不是承诺，模型确认旧候选
# 不适用（如换品类）时能立即补搜。代码里 max(1, ...) 钉死 ≥1——配 0 也会按 1 生效（永不为 0，
# 否则预算制退化回禁令制，死锁风险回归）。
REUSE_RETRIEVAL_BUDGET=1

# ========== token / 成本预算闸（F 块 FinOps）==========
# 单次任务（一棵 fork 树）的成本上限（美元）：每次模型调用一返回即把 token 换算成成本累进全树，
# 越硬线后请求模型前把「成本放大器」工具（fork / 检索 / 品类洞察）从工具表摘掉，逼用现有候选收尾。
# 设 <=0 关闭预算控制（只测不控，退回 usage.py 雏形语义）。
TOKEN_BUDGET_USD=0.50
# 软线比例：累计成本达 上限×此值 即记 soft 档（当前用于 metrics / 日志归因，不夺权）。
TOKEN_BUDGET_SOFT_RATIO=0.8
# 费率（每百万 token，美元）：(input / output / cache_read)。cache_read 命中享折扣。
# 默认档 = **deepseek-v4-flash 官方价**（¥1 / ¥2 / ¥0.02 每百万，百炼与官网同价）。
# **换模型必须回来改这三个数**：成本闸与 credit 配额都吃这张表，估错 = 闸提前夺权、用户额度缩水。
TOKEN_PRICE_INPUT=0.14
TOKEN_PRICE_OUTPUT=0.28
TOKEN_PRICE_CACHE_READ=0.0028

# ========== 用户级 credit 配额（M18）==========
# 每人每天（UTC 自然日）能烧掉的成本上限（美元）。TOKEN_BUDGET_USD 只管单次任务不失控，管不住
# 「同一个人连发一百条合规 query」——这道闸才管。到顶后 POST /api/task 直接 402，前端锁输入框。
# 跨天靠「换一行账」自然回满，无需定时任务。设 <=0 关闭配额（不设闸）。
# **只在 AUTH_ENABLED=true 时生效**：关掉鉴权时所有人共用一个假身份，没有可信身份可限。
# 用户看到的是 credit 而非美元：1 credit = $0.001，故 0.5 = 500 credits。
# 刻度参考（按上面 deepseek-v4-flash 的真实费率）：一轮典型购物任务约 4 credits → 500 ≈ 120 轮/天。
# 对真人足够宽松（没人一天搜 120 次购物），对脚本死刷才是真约束。
DAILY_QUOTA_USD=0.5

# ========== 最终清单展示上限 ==========
# item_picker 最终保留并展示的商品件数硬上限：合适的候选（过预算 + 排除词）全部展示，但封顶此值。
PICK_DISPLAY_CAP=20

# ========== 上下文压缩（M6 Cache Breakpoint）==========
# 保留最近几轮工具调用的全文（断点之后不压缩，留给模型当工作集）。
COMPRESS_KEEP_RECENT=3
# 较旧区每条工具结果的 token 上限（粗估 1 token≈4 字符），超过即尾部截断。
COMPRESS_MAX_TOOL_TOKENS=1500
# 是否给缓存前缀打 content-block ephemeral cache_control（显式前缀缓存）。
# DashScope 的 Qwen/DeepSeek 消费它（10% 计费档、5min 内保证命中）；标记写进 content-block 而非
# additional_kwargs（后者 langchain_openai 不转发）。纯 Anthropic 端点同样消费。见 compressor.py。
COMPRESS_CACHE_CONTROL=true

# ========== 对话历史 / 续聊 ==========
# 续聊回喂的历史轮数上限（一轮=一对 user/assistant）。同一 thread_id 复用即接上文，
# 只回喂精简的逐轮结论（不回放工具轨迹，省 token）。设 0 关闭续聊（每次全新开局）。
HISTORY_MAX_TURNS=10

# ========== JWT 鉴权（I 块 + M16 账户体系）==========
# **公网上线必须 =true**：M16 起前端有了真实的注册 / 登录页，账户、会话归属、侧栏历史全挂在
# token 身份上。留 false 时账户接口一律 404（登录页登不进去），且 user_id 退回「信前端传入」——
# 谁改一下请求体就能冒名读写他人偏好。仅本地跑 demo 图省事才关。
AUTH_ENABLED=false
# 签名密钥（HS256 对称）。开启鉴权但不配此项会**启动即报错**（fail-fast）——绝不用弱默认密钥（那
# 等于谁都能伪造 token）。生产用足够长的随机串（≥32 字节），且**不入库**（.env 已 gitignore）。
JWT_SECRET=change-me-to-a-long-random-secret-min-32-bytes
# token 有效期（秒），默认 24h。
JWT_EXP_SECONDS=86400
# 开发态发证口 /api/auth/token 开关——**独立于 AUTH_ENABLED**。它无密码给任意 user_id 发 token，
# 本质是「冒名工厂」，故不与鉴权共开关（否则开鉴权反而捅开越权洞）。M16 之后它已被真实的密码登录
# （/api/auth/register + /api/auth/login）取代，**生产务必保持 false**。
AUTH_DEV_TOKEN=false

# ========== 后台管理（热更新模型 / 检索 / 展示参数）==========
# 谁能进后台（用户名，逗号分隔）。空 = 没有管理员，后台整体关闭（不是「谁都能进」）。
#
# **只在 AUTH_ENABLED=true 时可用**：后台能换模型、能改召回阈值，是权限最高的面；鉴权关闭时身份
# 是前端自报的、可随意伪造，故那种情况下整个后台一律 403。本地想调参直接改本文件重启即可，不需要
# 那个页面——所以没给「本地便利」开逃生门。
#
# 改过的参数存在库里（config_overrides 表），重启仍生效，且**盖过本文件里的同名配置**。页面上每个
# 参数都标了来源（后台 / .env / 代码默认），发现某个值跟这里写的对不上时，先去后台看看是不是被改过。
#
# **后台可改的包括 OPENAI_BASE_URL / OPENAI_API_KEY**（换供应商用）。key 在页面上永不回显、只给
# sk-…a1b2 掩码核对，留空表示不改；要清掉某项改回本文件的值，点该项的「恢复」。
ADMIN_USERNAMES=

# ========== CORS 白名单 ==========
# 允许哪些网页源的 JS 调这套 API（逗号分隔）。缺省是本机 Vite 开发口。
# **公网部署务必收敛到自己的域名**：留 * 等于公开授权任何网站拿着用户的 token 调你的 API——
# 别人挂个页面，用户的 credit 额度和你的 LLM 账单就替他烧了。
# ALLOWED_ORIGINS=https://shopx.oiuu.de

# ========== 认证限流（防刷号 / 防撞库）==========
# **开放注册的站点必须开着它**：credit 配额（M19）是按人限的，而注册不设闸时「人」可以被脚本批量
# 制造——每个新号都合规地领一份日额度，加起来照样把 LLM 账单烧穿。两把闸缺一不可。
RATE_LIMIT_ENABLED=true
# ① IP 滑动窗口：挡「一台机器猛刷」。计数在进程内存里，重启清零——真正兜底的是下面的每日总量。
REGISTER_PER_IP_PER_HOUR=5
# 登录口限流防的是**撞库**（拿字典对着一个账号猛试），额度给得比注册宽，正常人重输密码碰不到。
LOGIN_PER_IP_PER_15MIN=20
# ② 全站每日新增用户上限：挡「换 IP 池刷号」——IP 能换，库里今天多出几行换不掉。设 0 关闭。
# 代价是对正常用户也是硬顶（当天名额满了得明天再来）；对 demo 站点，这远好过账单被刷爆只能关站。
MAX_NEW_USERS_PER_DAY=50
# 是否采信 X-Forwarded-For。**只有前面确实有反代时才置 true**（生产的 Caddy）：它是客户端可随手
# 伪造的 header，直接采信等于让攻击者自己填限流的 key，每请求换一个假 IP，窗口永远撞不满。
TRUST_PROXY_HEADERS=false

# ========== 账户与会话归属库（M16）==========
# users（人）+ threads（会话归谁）两张表。缺省用 SQLite，库文件落 var/globex.db —— 单机单 worker
# 部署下零容器零运维。**不能放 data/**：生产 compose 里 data 是只读挂载（:ro），SQLite 要写就得有个
# 可写的持久目录，故单列 var/（编排里挂命名卷，否则容器一重建账号全没）。
# 将来要多副本 / 多 worker，把这一行换成 Postgres DSN 即可，ORM 与查询一行都不用改：
#   DATABASE_URL=postgresql+asyncpg://user:pass@host/db
# DATABASE_URL=sqlite+aiosqlite:///./var/globex.db

# ========== 事件回放 Redis（断线重连补发 AGUI 事件，可选）==========
# 本项目**唯一**用到 Redis 的地方：每个 thread 一条 Redis Stream，前端重连时从 last_event_id
# 之后补发缺口事件。没起 Redis / 没装 redis 包都不影响主链路——断路器熔断后静默降级为「只直播、
# 无回放」。彻底关掉设 EVENT_REPLAY=false。
# EVENT_REDIS_URL=redis://localhost:6379/2
# EVENT_REPLAY=true
# EVENT_REPLAY_MAXLEN=200          # 单条流保留的最近事件数
# EVENT_REPLAY_TTL=21600           # 单条流存活秒数（滑动刷新），默认 6h

# ========== Langfuse 在线观测（调试主链路，可选）==========
# 只 trace 主对话链路（run_agent 主 loop + fork 子 Agent），不含 eval/ 与 judge LLM。
# 挂在 invoke 层 config["callbacks"]，未装包 / 未配 key / ENABLED 非真都安静降级为无观测，主链路无感。
# host 不设 SDK 会静默发到 EU 默认区——这里显式用 US 区地址。装包：uv add "langfuse>=4.12"。
LANGFUSE_ENABLED=false
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
# 可选。只用于把告警里的 trace 链接拼成直达 URL（.../project/<id>/traces/<trace_id>）；
# 不配则退化为通用重定向路径 .../trace/<trace_id>。在 Langfuse 项目设置页可查到。
LANGFUSE_PROJECT_ID=

# ========== 工具 RT 告警（refdocs 16-3 §6）==========
# /metrics 是被动的（没人来拉就没人知道 P95 涨了），告警器补上主动通知的那一半：后台每
# ALERT_CHECK_INTERVAL_SEC 秒评估一次规则，越线推 webhook。**没配 webhook 也一定落 logger.error**。
# 规则与阈值在 app/observability/alerts.py 的 DEFAULT_RULES —— 那里的初值是占位，须按真实基线
# 校准（先跑一遍评测，从 /metrics 读出各工具 P95，阈值定在基线的 1.5~2 倍）。
ALERT_ENABLED=true
ALERT_CHECK_INTERVAL_SEC=60
# 同一条规则持续越线时，重复提醒的最小间隔（秒）。防告警风暴。
ALERT_COOLDOWN_SEC=900
# 留空则只落日志。钉钉/飞书群机器人或 Slack Incoming Webhook 的地址。
ALERT_WEBHOOK_URL=
# webhook body 形状：dingtalk（默认）/ slack / generic —— 三家的 text 字段不是一回事。
ALERT_WEBHOOK_KIND=dingtalk

# ========== 安全护栏（refdocs 16-6 §1-2 / §5）==========
# 四层防御里 L1 白名单 / L3 工具返回内容过滤 / L4 输出脱敏都是**常开**的确定性代码，无开关——
# 安全层不该有「关掉试试」的选项。唯一可调的是日志脱敏：开发时想看用户 query 原文可临时关掉。
# 打开时（默认）经 structlog 打出的日志里，query 只留首尾、user_id 哈希、密钥全 mask。
LOG_SANITIZE=true

# ========== 任务准入：双池优先级队列 + 幂等（refdocs 16-5 §2-3）==========
# 按对话历史轮数把请求分成 normal / heavy 两池，各有独立槽位与有界等待队列——长续聊最多占满
# heavy 的槽，短对话的槽永远留着。两池容量之和 = 全局最大并发主 AgentLoop 数。
TASK_NORMAL_SLOTS=5
TASK_HEAVY_SLOTS=3
# 高峰再平衡：normal 排队人数达 TASK_REBALANCE_PENDING 时，heavy 容量临时压到 MIN（不抢占已在跑
# 的任务，随其退出自然回落）；normal 队列清空后恢复。不设 0——长任务也是用户，饿死它是拒绝服务。
TASK_HEAVY_SLOTS_MIN=1
TASK_REBALANCE_PENDING=3
# 每池等待队列深度上限，超了才 429。有界排队换体验，上限守住背压（无界排队会堆成「看似没满
# 其实全在等」的假象，用户对着进度条空等更久）。
TASK_QUEUE_DEPTH=8
TASK_RETRY_AFTER_SEC=10
# 该 thread 历史轮数 ≥ 它即判为 heavy（续聊越长，上下文越大、跑得越久）。
TASK_HEAVY_TURNS=8
# 排队位置反馈里「预估等待」用的单任务平均秒数。粗略常数即可——Agent 任务耗时长尾很重，
# 加权移动平均会被拖得离谱，不如一个诚实的量级。
TASK_AVG_SECONDS=30
# 幂等第 3 层：同 (user_id, query) 在此窗口内重复提交视为重复。只对**不自带 thread_id** 的调用方
# （脚本 / 裸 API）生效——前端 connect-first 自带 thread_id，它的重复由第 1 层 active_tasks 管。
TASK_DEDUP_WINDOW_SEC=5

# ========== 模型路由降级（refdocs 16-4 §3 / §6）==========
# 按「全树剩余预算比例」四档降级：>50% main（主力模型）/ 20~50% lite（换便宜档）/
# 5~20% minimal（便宜档 + 简洁 hint + 机制上收走检索与 fork 工具）/ <5% fallback（不调 LLM，
# 用已有候选拼一个诚实的清单）。三条分界线：
BUDGET_TIER_LITE_RATIO=0.5
BUDGET_TIER_MINIMAL_RATIO=0.2
BUDGET_TIER_FALLBACK_RATIO=0.05
# 便宜档模型。**不配即复用 LLM_FAST 的做法**（同一个 hybrid 模型只关 reasoning）——实测换更弱的
# 小模型在 Agent 任务上反而更慢更贵（多绕几轮 + 自纠偏差）。真想换模型才配这项。
# LLM_LITE=qwen-turbo
